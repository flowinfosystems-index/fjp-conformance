# FJP-CONF static site — Railway deployment
#
# Serves:
#   /                    → FJP landing page
#   /success             → post-purchase thank you page
#   /conformance/v0.1/   → conformance spec page

{
	auto_https off
	admin off
}

:{$PORT} {
	root * /srv
	encode gzip

	@conformance_bare path /conformance /conformance/
	redir @conformance_bare /conformance/v0.1/ 302

	# /success serves the thank you page (try_files rewrites to the file)
	@success path /success /success/
	rewrite @success /success.html

	file_server

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy no-referrer
		-Server
	}
}
